---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			article {
				padding-bottom: 3rem;
			}
			.hero-image {
				width: min(1040px, calc(100% - 2rem));
				margin: 0 auto 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 8px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 0 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				width: min(960px, calc(100% - 2rem));
				margin: 0 auto 2rem;
				padding: 3.5rem 1rem 2rem;
				border-bottom: 1px solid var(--border);
				text-align: left;
			}
			.title h1 {
				max-width: 860px;
				margin: 0.4rem 0 0.75rem;
				font-size: 3rem;
				line-height: 1.05;
			}
			.description {
				max-width: 780px;
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1.15rem;
				line-height: 1.55;
			}
			.date {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.category-pill {
				padding: 0.25rem 0.55rem;
				border-radius: 999px;
				background: #eef9f7;
				color: var(--accent-dark);
				font-size: 0.78rem;
				font-weight: 700;
			}
			.last-updated-on {
				font-style: italic;
			}
			.prose :global(h2) {
				margin-top: 2.2rem;
			}
			.prose :global(h3) {
				margin-top: 1.6rem;
			}
			.prose :global(table) {
				display: block;
				overflow-x: auto;
				border-collapse: collapse;
				font-size: 0.95rem;
			}
			.prose :global(th),
			.prose :global(td) {
				padding: 0.55rem 0.65rem;
				border: 1px solid var(--border);
			}
			.prose :global(th) {
				background: var(--surface-muted);
				color: rgb(var(--black));
			}
			@media (max-width: 720px) {
				.title {
					padding-top: 2rem;
				}
				.title h1 {
					font-size: 2rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="title">
					<div class="date">
						{category && <span class="category-pill">{category}</span>}
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					<p class="description">{description}</p>
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
