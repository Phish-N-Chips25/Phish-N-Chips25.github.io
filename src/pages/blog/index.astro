---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog"))
  .filter((post) => post.data.pubDate.valueOf() <= Date.now())
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryOptions = Array.from(
  new Set(posts.map((post) => post.data.category).filter(Boolean))
).sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1120px;
			}
			.blog-header {
				display: grid;
				gap: 0.75rem;
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--border);
			}
			.blog-header h1 {
				margin: 0;
				font-size: 2.4rem;
			}
			.blog-header p {
				max-width: 760px;
				margin: 0;
				color: rgb(var(--gray));
			}
			.category-filter {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1rem;
				margin-bottom: 2rem;
				padding: 0;
			}
			.category-filter label {
				font-weight: 600;
				color: #0f172a;
			}
			.category-filter select {
				min-height: 42px;
				padding: 0.4rem 0.75rem;
				border-radius: 8px;
				border: 1px solid var(--border);
				background: #fff;
				font-size: 1rem;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				column-gap: 2rem;
				row-gap: 4.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				min-height: 230px;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 8px;
			}
			ul li a {
				display: flex;
				flex-direction: column;
				height: 100%;
				padding: 1.35rem;
				border: 1px solid var(--border);
				border-radius: 8px;
				background: #fff;
			}
			ul li a:hover {
				border-color: #9ccbc5;
				box-shadow: 0 12px 30px rgba(17, 24, 39, 8%);
			}
			.category-pill {
				align-self: flex-start;
				margin-bottom: 1rem;
				padding: 0.25rem 0.55rem;
				border-radius: 999px;
				background: #eef9f7;
				color: var(--accent-dark);
				font-size: 0.78rem;
				font-weight: 700;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1.15rem;
				line-height: 1.25;
			}
			.description {
				margin: 0.75rem 0 1rem;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.5;
			}
			.date {
				margin: auto 0 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.empty-state {
				padding: 2rem;
				text-align: center;
				border: 1px dashed var(--border);
				border-radius: 8px;
				color: #475569;
				background-color: var(--surface-muted);
			}
			@media (max-width: 720px) {
				ul {
					grid-template-columns: 1fr;
					row-gap: 2.5rem;
				}
				.blog-header h1 {
					font-size: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="blog-header">
				<p class="eyebrow">Project documentation</p>
				<h1>Research and progress log</h1>
				<p>
					Weekly updates from Team 10 on cybersecurity, physical security, autonomous robotics and AI-assisted decision making.
				</p>
			</header>
			<form class="category-filter" data-category-form>
				<label for="category">Filter by challenge</label>
				<select
					id="category"
					name="category"
					data-category-filter
				>
					<option value="all" selected>
						All challenges
					</option>
					{categoryOptions.map((category) => (
						<option value={category}>
							{category}
						</option>
					))}
				</select>
			</form>
			<section>
				<p class="empty-state" data-empty-state hidden>
					No posts available for this category yet.
				</p>
				<ul data-blog-list>
					{posts.map((post) => (
						<li data-blog-item data-category={post.data.category ?? "Uncategorized"}>
							<a href={`/blog/${post.id}/`}>
								<span class="category-pill">{post.data.category ?? "Research"}</span>
								{post.data.heroImage && (
									<Image width={720} height={360} src={post.data.heroImage} alt="" />
								)}
								<h4 class="title">{post.data.title}</h4>
								<p class="description">{post.data.description}</p>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
		<script type="module">
			document.addEventListener("DOMContentLoaded", () => {
				const select = document.querySelector('[data-category-filter]');
				const items = document.querySelectorAll('[data-blog-item]');
				const emptyState = document.querySelector('[data-empty-state]');
				if (!select || !items.length) return;

				const updateVisibility = (category) => {
					let visibleCount = 0;
					items.forEach((item) => {
						const itemCategory = item.getAttribute('data-category') ?? "Uncategorized";
						const shouldShow = category === "all" || itemCategory === category;
						item.style.display = shouldShow ? "" : "none";
						if (shouldShow) visibleCount += 1;
					});
					if (emptyState) emptyState.hidden = visibleCount !== 0;
				};

				select.addEventListener("change", () => {
					updateVisibility(select.value);
				});

				updateVisibility(select.value);
			});
		</script>
	</body>
</html>
