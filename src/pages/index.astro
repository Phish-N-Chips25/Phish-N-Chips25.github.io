---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import TeamLogo from "../images/logo.jpg";
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <main class="homepage">
            <section class="homepage__hero">
                <img
                    class="homepage__logo"
                    src={TeamLogo.src}
                    width="84"
                    height="84"
                    alt="Team 10 shield logo"
                    loading="eager"
                />
                <div>
                    <p class="homepage__eyebrow">Team 10 - MEIA ISEP</p>
                    <h1 class="homepage__title">Cybersecurity research for autonomous physical protection</h1>
                    <p class="homepage__lead">
                        We document the development of an AI-assisted surveillance platform that connects endpoint telemetry, identity verification, mobile robotics and multi-agent coordination.
                    </p>
                </div>
            </section>

            <section class="homepage__grid" aria-label="Project focus areas">
                <article class="homepage__panel">
                    <p class="eyebrow">Research Focus</p>
                    <h2>Cyber-physical security</h2>
                    <p>
                        Our current challenge studies how digital alerts and physical observations can be correlated inside a single autonomous decision framework.
                    </p>
                </article>
                <article class="homepage__panel">
                    <p class="eyebrow">Technical Stack</p>
                    <h2>AI, robotics and agents</h2>
                    <ul>
                        <li>ROS 2, Nav2 and Webots</li>
                        <li>LLM-based cyber analysis</li>
                        <li>Face recognition and object detection</li>
                    </ul>
                </article>
                <article class="homepage__panel">
                    <p class="eyebrow">Documentation</p>
                    <h2>Weekly progress log</h2>
                    <p>
                        Each post records decisions, implementation progress, risks and next steps for the academic evaluation.
                    </p>
                </article>
            </section>

            <div class="homepage__actions">
                <a class="button-link" href="/blog/">Read the blog</a>
                <a class="button-link secondary" href="/about/">Meet the team</a>
            </div>
        </main>
        <Footer />
    </body>
</html>